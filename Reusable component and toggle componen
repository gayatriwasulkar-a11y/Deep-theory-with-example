//App.jsx
import React, { useState } from "react";
import  Input  from "./components/Input/Input";

export default function App() {
  const [name, setName] = useState("");
  const [error, setError] = useState("");

  const handleSubmit = (e) => {
    e.preventDefault();
    if (!name) setError("Name is required");
    else setError("");
  };

  return (
    <form className="form-container">
    <form onSubmit={handleSubmit} style={{ maxWidth: 300, margin:5 }}>
      <Input id="name" value={name} onChange={(e) => setName(e.target.value)}>
      <h2>Registration Form</h2>
        <Input.Label>Name: </Input.Label>
        <Input.Field placeholder="Enter your name" />
        {error && <Input.Error>{error}</Input.Error>}
      </Input>

      <button type="submit" style={{ padding: "8px 16px", marginTop:8  }}>
        <onclick>Submit</onclick>
      </button>
    </form>
    </form>
  );
}
//components/Input/Input.jsx
import React, { createContext, useContext } from "react";
import  "./Input.css";

const InputContext = createContext();

function Input({ children, ...props }) {
  return (
    <div className="input-wrapper">
      <InputContext.Provider value={props}>{children}</InputContext.Provider>
    </div>
  );
}

Input.Label = function Label({ children }) {
  const { id } = useContext(InputContext);
  return (
    <label htmlFor={id} className="input-label">
      {children}
    </label>
  );
};

Input.Field = function Field(props) {
  const context = useContext(InputContext);
  return <input {...context} {...props} className="input-field" />;
};

Input.Error = function Error({ children }) {
  return <p className="input-error">{children}</p>;
};

export default Input;
