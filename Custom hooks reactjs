import React, { useState, useEffect } from "react";

function Counter() {
  const [count, setCount] = useState(0);

  useEffect(() => {
    console.log("Effect runs only once");
    setCount(prev => prev + 1);
  }, []); 

  return (
    <div>
      <h2>Count: {count}</h2>
    </div>
  );
}

export default Counter;

