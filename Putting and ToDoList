7.Using Advanced Features:-
class Task {
  constructor(title, priority = "LOW", dueDate = null) {
    this.id = Date.now();
    this.title = title;
    this.priority = priority; 
    this.status = "PENDING"; 
    this.dueDate = dueDate ? new Date(dueDate) : null;
    this.active = true; 
    this.createdAt = new Date();
    this.updatedAt = new Date();
  }

  update(data) {
    Object.assign(this, data);
    this.updatedAt = new Date();
  }

  softDelete() {
    this.active = false;
    this.updatedAt = new Date();
  }
}

class TaskManager {
  constructor() {
    this.tasks = [];
  }

  addTask(title, priority, dueDate) {
    const task = new Task(title, priority, dueDate);
    this.tasks.push(task);
    return task;
  }

  searchByTitle(keyword) {
    return this.tasks.filter(
      task =>
        task.active &&
        task.title.toLowerCase().includes(keyword.toLowerCase())
    );
  }

  filterByStatus(status) {
    return this.tasks.filter(
      task => task.active && task.status === status
    );
  }

  filterByPriority(priority) {
    return this.tasks.filter(
      task => task.active && task.priority === priority
    );
  }

  getActiveTasks() {
    return this.tasks.filter(task => task.active);
  }

  getInactiveTasks() {
    return this.tasks.filter(task => !task.active);
  }
}
//example
const manager = new TaskManager();

manager.addTask("Finish report", "HIGH", "2026-02-25");
manager.addTask("Buy Books", "LOW", "2026-02-20");
manager.addTask("Prepare presentation", "MEDIUM", "2026-02-22");

manager.tasks[0].update({ status: "COMPLETED" });

manager.tasks[1].softDelete();

console.log("Search 'report':", manager.searchByTitle("report"));
console.log("Completed tasks:", manager.filterByStatus("COMPLETED"));
console.log("High priority tasks:", manager.filterByPriority("HIGH"));
console.log("Active tasks:", manager.getActiveTasks());
console.log("Inactive tasks:", manager.getInactiveTasks());


